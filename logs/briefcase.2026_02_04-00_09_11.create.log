pyproject.toml:
[build-system]
requires = ["hatchling", "hatch-vcs"]
build-backend = "hatchling.build"

[project]
name = "lucid"
dynamic = ["version"]
description = "LUCID - Lightsource Unified Control Interface Dashboard"
readme = "README.md"
license = "BSD-3-Clause"
requires-python = ">=3.11"
authors = [
    { name = "ALS Controls Team" },
]
keywords = [
    "control-system",
    "data-acquisition",
    "scientific-instruments",
    "beamline",
    "lucid",
]
classifiers = [
    "Development Status :: 3 - Alpha",
    "Environment :: X11 Applications :: Qt",
    "Intended Audience :: Science/Research",
    "License :: OSI Approved :: BSD License",
    "Operating System :: OS Independent",
    "Programming Language :: Python :: 3",
    "Programming Language :: Python :: 3.11",
    "Programming Language :: Python :: 3.12",
    "Topic :: Scientific/Engineering",
]
dependencies = [
    "PySide6>=6.6",
    "pydantic>=2.0",
    "pyyaml>=6.0",
    "loguru>=0.7",
    "sentry-sdk[loguru]>=2.0",
    "mistune>=3.0",
    "psutil>=5.9",
    "pyqt-toast-notification>=1.0",
    "pyqtgraph>=0.13",
    "qtawesome>=1.3",
    # acquire
    "bluesky>=1.10",
    "ophyd>=1.7",
    # tiled
    "tiled[client]>=0.1.0",
    # keycloak
    "aiohttp>=3.8",
    "aiohttp-socks>=0.8",
    # ipython
    "qtconsole>=5.5",
    "ipykernel>=6.0",
]

[project.optional-dependencies]
bcs = [
    "bcsophyd @ git+https://git.als.lbl.gov/bcs/bluesky/bcsophyd-zmq",
]
claude = [
    "pyside-claude",
]
dev = [
    "pytest>=8.0",
    "pytest-cov>=4.0",
    "pytest-qt>=4.2",
    "ruff>=0.1",
    "mypy>=1.8",
    "pre-commit>=3.6",
]
docs = [
    "sphinx>=7.0,<9.0",
    "myst-parser>=2.0",
    "sphinx-immaterial>=0.12",
]

[project.scripts]
lucid = "lucid.main:cli"

[project.gui-scripts]
lucid-gui = "lucid.main:cli"

[project.urls]
Homepage = "https://github.com/als-computing/lucid"
Documentation = "https://als-computing.github.io/lucid"
Repository = "https://github.com/als-computing/lucid"

[tool.hatch.metadata]
allow-direct-references = true

[tool.hatch.version]
source = "vcs"
fallback-version = "0.0.0.dev0"

[tool.hatch.build.hooks.vcs]
version-file = "src/lucid/_version.py"

[tool.hatch.build.targets.sdist]
include = [
    "/src",
]

[tool.hatch.build.targets.wheel]
packages = ["src/lucid"]

[tool.ruff]
line-length = 100
target-version = "py311"

[tool.ruff.lint]
select = [
    "E",      # pycodestyle errors
    "W",      # pycodestyle warnings
    "F",      # Pyflakes
    "I",      # isort
    "B",      # flake8-bugbear
    "C4",     # flake8-comprehensions
    "UP",     # pyupgrade
]
ignore = [
    "E501",   # line too long (handled by formatter)
]

[tool.ruff.lint.isort]
known-first-party = ["lucid"]

[tool.mypy]
python_version = "3.11"
warn_return_any = true
warn_unused_configs = true
disallow_untyped_defs = true

[tool.pytest.ini_options]
testpaths = ["tests"]
addopts = "-ra -q"
qt_api = "pyside6"

[tool.coverage.run]
source = ["src/lucid"]
branch = true

[tool.coverage.report]
exclude_lines = [
    "pragma: no cover",
    "if TYPE_CHECKING:",
    "if __name__ == .__main__.:",
]

# =============================================================================
# Briefcase Configuration (Native App Packaging)
# =============================================================================

[tool.briefcase]
project_name = "LUCID"
bundle = "gov.lbl.als"
version = "0.1.0"
url = "https://als.lbl.gov"
license.file = "LICENSE"
author = "ALS Controls Team"
author_email = "controls@lbl.gov"

[tool.briefcase.app.lucid]
formal_name = "LUCID"
description = "Advanced Light Source Control System"
long_description = """LUCID is a modern, unified control system for scientific
data acquisition and hardware controls at the Advanced Light Source facility."""
icon = "resources/lucid"
sources = ["src/lucid"]
requires = [
    # Core UI
    "PySide6>=6.6",
    "pyqtgraph>=0.13",
    "qtawesome>=1.3",
    "pyqt-toast-notification>=1.0",

    # Data/Config
    "pydantic>=2.0",
    "pydantic-settings>=2.0",
    "pyyaml>=6.0",

    # Logging & Monitoring
    "loguru>=0.7",
    "sentry-sdk[loguru]>=2.0",
    "psutil>=5.9",

    # Markdown rendering
    "mistune>=3.0",

    # Async/HTTP
    "aiohttp>=3.8",
    "aiohttp-socks>=0.8",

    # Data acquisition
    "bluesky>=1.10",
    "ophyd>=1.7",
    "tiled[client]>=0.1.0",

    # IPython integration
    "qtconsole>=5.5",
    "ipykernel>=6.0",
    "ipython>=8.0",

    # Utilities
    "platformdirs>=4.0",
    "watchfiles>=0.20",
    "python-dotenv>=1.0",
    "typing-extensions>=4.0",
    "cachetools>=5.0",
    "cryptography>=41.0",
    "bidict>=0.23",

    # Sub-projects (from local wheels via --find-links)
    "epics-pyside",
    "pyside-claude",
]

[tool.briefcase.app.lucid.macOS]
requires = []

[tool.briefcase.app.lucid.windows]
requires = []

[tool.briefcase.app.lucid.linux]
requires = []
system_requires = []

